{
  "name": "donkey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest --exclude \"**/__manual__/**\"",
    "lint": "pnpm -r lint",
    "lint:actions": "bash scripts/ci/actionlint.sh",
    "smoke:claude-provider": "npm exec --yes -- pnpm@10.12.1 --filter @donkey/core smoke:claude-provider",
    "typecheck": "pnpm -r typecheck",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
