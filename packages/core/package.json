{
  "name": "@tekon/core",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest --exclude \"**/__manual__/**\"",
    "test:unit": "vitest --run --exclude \"**/*.e2e.test.ts\" --exclude \"**/__manual__/**\"",
    "test:e2e": "vitest --run __tests__/runtime/worktree-manager.e2e.test.ts __tests__/phase1/kernel.e2e.test.ts __tests__/workflow/engine-template.e2e.test.ts __tests__/workflow/engine-recovery.e2e.test.ts __tests__/workflow/engine-gate-repair.e2e.test.ts __tests__/workflow/engine-worktree.e2e.test.ts __tests__/workflow/dynamic-constraint.e2e.test.ts",
    "smoke:claude-provider": "vitest --run __manual__/claude-code-provider.smoke.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1"
  }
}
